# Copy to .env and edit. ALL values have working zero-server defaults (SQLite + file MLflow),
# so `pytest` and `automl-run` work with no Docker. docker compose sets the Postgres/MLflow-server
# values via each service's `environment:` block, so you usually don't need to touch this for compose.

# ---- Active example ----------------------------------------------------------
PIPELINE_CONFIG=examples/buyer_stage/pipeline.yaml

# ---- Online store (any SQLAlchemy URL) ---------------------------------------
# Local default is SQLite; compose overrides to Postgres.
SERVING_DB_URL=sqlite:///./data/serving.db

# ---- MLflow tracking + registry ----------------------------------------------
# SQLite-backed URI enables the Model Registry locally; compose uses http://mlflow:5000.
MLFLOW_TRACKING_URI=sqlite:///./data/mlflow.db
MLFLOW_EXPERIMENT=tabular-automl-template

# ---- Notifications (Apprise; one URL fans out) -------------------------------
# Empty = log-only (safe default). Example: slack://tokenA/tokenB/tokenC
APPRISE_URL=

# ---- Optional ----------------------------------------------------------------
# RUN_DATE=2026-06-29
# DATA_DIR=data

# ---- Dashboard (optional; `dashboard` compose profile / `make dashboard`) -----
# Base URLs used ONLY for the control panel's Health tiles + deep links. Compose sets
# these for the in-network service names; for a local run point them at localhost.
# API_URL=http://localhost:8000
# DAGSTER_URL=http://localhost:3000
# MLFLOW_UI_URL=http://localhost:5000
