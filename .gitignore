# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
env/

# Tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage_html_report/
# Dagster local instance (runtime state; created by `dagster dev` / compose)
.dagster/

# Secrets / local config — only .env.example is committed
.env
.env.*
!.env.example

# Machine-specific compose override (e.g. local port remaps) — never committed
docker-compose.override.yml

# Data & artifacts (do not commit real data or model artifacts)
mlruns/
*.duckdb
*.duckdb.wal
data/
examples/*/sample_data/*.csv
examples/*/sample_data/*.parquet
# Checked-in golden parity fixtures are the ONLY allowed data artifacts:
!examples/*/golden/*.parquet

# OS / editor
.DS_Store
.vscode/
.idea/
*.iml
